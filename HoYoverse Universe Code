<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>HoYoverse Link Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@400;500;600;700&family=Exo+2:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-0: #05070d;
    --bg-1: #0a0f1c;
    --bg-2: #111729;
    --surface: rgba(20, 28, 48, 0.65);
    --surface-hi: rgba(28, 38, 64, 0.85);
    --border: rgba(120, 180, 255, 0.12);
    --border-hi: rgba(120, 200, 255, 0.45);

    --text-1: #e8f0ff;
    --text-2: #aab6cf;
    --text-3: #6c7a96;

    /* Brand accents */
    --hoyo:    #4cc5ff;
    --hi3:     #ff5b9e;
    --genshin: #5dd2c4;
    --hsr:     #c490ff;
    --zzz:     #ffd23f;

    --radius: 16px;
    --radius-sm: 10px;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg-0);
    color: var(--text-1);
    font-family: 'Exo 2', 'Rajdhani', sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }

  /* Animated atmospheric background */
  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background:
      radial-gradient(900px circle at 12% 8%,  rgba(76,197,255,0.18), transparent 55%),
      radial-gradient(800px circle at 88% 22%, rgba(255,91,158,0.14), transparent 60%),
      radial-gradient(800px circle at 88% 70%, rgba(196,144,255,0.12), transparent 60%),
      radial-gradient(1000px circle at 50% 100%, rgba(93,210,196,0.10), transparent 55%);
    z-index: -2;
    pointer-events: none;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(120,180,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(120,180,255,0.05) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    z-index: -1;
    pointer-events: none;
  }

  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 64px 28px 96px;
  }

  /* Header */
  header.hero {
    text-align: center;
    margin-bottom: 72px;
    opacity: 0;
    transform: translateY(20px);
    animation: rise 0.9s 0.05s forwards cubic-bezier(.2,.7,.2,1);
  }
  .hero .eyebrow {
    font-family: 'Orbitron', sans-serif;
    font-size: 12px;
    letter-spacing: 0.5em;
    color: var(--hoyo);
    text-transform: uppercase;
    margin-bottom: 18px;
    text-shadow: 0 0 18px rgba(76,197,255,0.5);
  }
  .hero h1 {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    line-height: 1.05;
    margin: 0 0 18px;
    background: linear-gradient(120deg, #ffffff 0%, #cfe6ff 40%, #4cc5ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: 0.04em;
  }
  .hero p {
    color: var(--text-2);
    font-size: 1rem;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .hero .divider {
    margin: 28px auto 0;
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--hoyo), transparent);
    box-shadow: 0 0 18px var(--hoyo);
  }

  /* Category sections */
  .category {
    margin-bottom: 64px;
    opacity: 0;
    transform: translateY(24px);
    animation: rise 0.8s forwards cubic-bezier(.2,.7,.2,1);
  }
  .category:nth-of-type(1) { animation-delay: 0.20s; }
  .category:nth-of-type(2) { animation-delay: 0.28s; }
  .category:nth-of-type(3) { animation-delay: 0.36s; }
  .category:nth-of-type(4) { animation-delay: 0.44s; }
  .category:nth-of-type(5) { animation-delay: 0.52s; }

  .category-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--border);
    position: relative;
  }
  .category-header::after {
    content: "";
    position: absolute;
    left: 0; bottom: -1px;
    width: 120px;
    height: 1px;
    background: var(--accent, var(--hoyo));
    box-shadow: 0 0 12px var(--accent, var(--hoyo));
  }
  .category-badge {
    width: 10px;
    height: 28px;
    border-radius: 3px;
    background: var(--accent, var(--hoyo));
    box-shadow: 0 0 18px var(--accent, var(--hoyo));
  }
  .category-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    letter-spacing: 0.08em;
    margin: 0;
    color: var(--text-1);
  }
  .category-meta {
    margin-left: auto;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.3em;
    color: var(--text-3);
    text-transform: uppercase;
  }

  /* Card Grid */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  /* Card */
  .card {
    --accent: var(--hoyo);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 170px;
    padding: 22px 22px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text-1);
    overflow: hidden;
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    transition:
      transform 0.35s cubic-bezier(.2,.7,.2,1),
      border-color 0.35s ease,
      background 0.35s ease,
      box-shadow 0.35s ease;
  }

  /* corner accent line */
  .card::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 50px; height: 1px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    opacity: 0.6;
    transition: width 0.4s ease, opacity 0.4s ease;
  }
  .card::after {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 1px; height: 50px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    opacity: 0.6;
    transition: height 0.4s ease, opacity 0.4s ease;
  }

  .card:hover {
    transform: translateY(-6px) scale(1.015);
    border-color: var(--border-hi);
    background: var(--surface-hi);
    box-shadow:
      0 18px 40px -18px rgba(0,0,0,0.6),
      0 0 0 1px var(--accent),
      0 0 32px -8px var(--accent);
  }
  .card:hover::before { width: 100%; opacity: 1; }
  .card:hover::after { height: 100%; opacity: 1; }

  /* Hover sheen */
  .card .sheen {
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.7s ease;
    pointer-events: none;
  }
  .card:hover .sheen { transform: translateX(100%); }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .card-icon {
    width: 42px; height: 42px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 10px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    color: var(--accent);
    transition: transform 0.4s ease, background 0.4s ease, border-color 0.4s ease;
  }
  .card:hover .card-icon {
    transform: rotate(-6deg) scale(1.08);
    background: rgba(255,255,255,0.06);
    border-color: var(--accent);
  }
  .card-icon svg { width: 22px; height: 22px; }

  .arrow {
    width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    color: var(--text-3);
    transition: transform 0.35s ease, background 0.35s ease, color 0.35s ease;
  }
  .card:hover .arrow {
    background: var(--accent);
    color: #05070d;
    transform: rotate(-45deg) translateX(2px);
  }
  .arrow svg { width: 14px; height: 14px; }

  .card-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    margin: 0 0 6px;
    color: var(--text-1);
  }
  .card-url {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    color: var(--text-3);
    text-transform: uppercase;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.35s ease;
  }
  .card:hover .card-url { color: var(--accent); }

  /* Category accents */
  .cat-hoyo .category-badge,
  .cat-hoyo .category-header::after { background: var(--hoyo); box-shadow: 0 0 18px var(--hoyo); }
  .cat-hoyo .card { --accent: var(--hoyo); }

  .cat-hi3 .category-badge,
  .cat-hi3 .category-header::after { background: var(--hi3); box-shadow: 0 0 18px var(--hi3); }
  .cat-hi3 .card { --accent: var(--hi3); }

  .cat-genshin .category-badge,
  .cat-genshin .category-header::after { background: var(--genshin); box-shadow: 0 0 18px var(--genshin); }
  .cat-genshin .card { --accent: var(--genshin); }

  .cat-hsr .category-badge,
  .cat-hsr .category-header::after { background: var(--hsr); box-shadow: 0 0 18px var(--hsr); }
  .cat-hsr .card { --accent: var(--hsr); }

  .cat-zzz .category-badge,
  .cat-zzz .category-header::after { background: var(--zzz); box-shadow: 0 0 18px var(--zzz); }
  .cat-zzz .card { --accent: var(--zzz); }

  /* Footer */
  footer {
    text-align: center;
    padding: 36px 20px 0;
    color: var(--text-3);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    border-top: 1px solid var(--border);
    margin-top: 40px;
  }
  footer span { color: var(--hoyo); }

  /* Keyframes */
  @keyframes rise {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive */
  @media (max-width: 980px) {
    .grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .container { padding: 44px 18px 72px; }
    .grid { grid-template-columns: 1fr; gap: 14px; }
    .card { min-height: 130px; padding: 20px; }
    .category { margin-bottom: 48px; }
    .category-meta { display: none; }
    .hero { margin-bottom: 52px; }
  }
</style>
</head>
